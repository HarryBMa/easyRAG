# ── Turso (libSQL) ──────────────────────────────────────────────────────────
# Local dev: leave as-is (uses file-based SQLite)
# Production: use your Turso database URL
TURSO_DATABASE_URL=file:data/protocolsync.db
TURSO_AUTH_TOKEN=

# ── Milvus ───────────────────────────────────────────────────────────────────
MILVUS_ADDRESS=localhost:19530
# For Zilliz Cloud (managed Milvus): set MILVUS_TOKEN
MILVUS_TOKEN=

# ── Ollama / Local LLM ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Model to use for structuring + categorization
# Recommended: medgemma (pull with: ollama pull medgemma)
# Fallback: llama3.2, mistral, phi3
OLLAMA_MODEL=medgemma

# ── Embeddings (for semantic search) ─────────────────────────────────────────
# Uses OpenAI text-embedding-3-small by default
# Set OPENAI_API_KEY even if using Ollama for LLM (embeddings still use OpenAI)
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Supabase Edge Functions (PubMed verification) ───────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── PowerSync (optional — enables real-time offline sync) ───────────────────
# Leave empty to run without PowerSync (direct API only)
VITE_POWERSYNC_URL=
VITE_POWERSYNC_TOKEN=

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
