# ── Supabase Postgres ────────────────────────────────────────────────────────
# Connection string for Supabase Postgres (includes pgvector for embeddings)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=

# ── Supabase Auth + API ──────────────────────────────────────────────────────
# Project URL and anon key (safe to expose to browser)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service-role key — server-side only, NEVER expose to the browser
# Used to verify user JWTs in API routes
SUPABASE_SERVICE_ROLE_KEY=

# Vite exposes VITE_* vars to the browser bundle
VITE_SUPABASE_URL=        # same value as SUPABASE_URL
VITE_SUPABASE_ANON_KEY=   # same value as SUPABASE_ANON_KEY

# ── Docling Serve (document parsing) ─────────────────────────────────────────
# REST API for PDF/DOCX/image conversion — run via docker-compose
# Start with: docker compose up docling
DOCLING_URL=http://localhost:5001

# ── OpenDataLoader PDF (PDF fallback) ────────────────────────────────────────
# High-accuracy PDF-to-Markdown extraction (ranks #1 on open-source benchmarks).
# Requires Java 11+ on PATH. Enabled by default when Java is available.
# Set to 'false' to skip this step and go straight to pdf-parse.
OPENDATALOADER_ENABLED=true

# ── Ollama / Local LLM ───────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
# Model to use for structuring + categorization
# Recommended: medgemma (pull with: ollama pull medgemma)
# Fallback: llama3.2, mistral, phi3
OLLAMA_MODEL=medgemma
# Vision model for OCR of images, graphs and charts (LLM-based)
# Pull with: ollama pull deepseek-vl2
# Falls back to Tesseract.js if Ollama is unavailable
DEEPSEEK_OCR_MODEL=deepseek-vl2

# ── Embeddings (for semantic search) ─────────────────────────────────────────
# Uses OpenAI text-embedding-3-small by default
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ── Literature databases (optional — increases source coverage) ──────────────
NCBI_API_KEY=                  # PubMed rate limit: 3 req/s → 10 req/s with key
SEMANTIC_SCHOLAR_API_KEY=      # Optional — 100 req/5min without, 1 req/s with
OPENALEX_EMAIL=                # Polite pool: 10 req/s (vs 100k/day shared pool)

# ── PowerSync (optional — enables real-time offline sync) ───────────────────
# Leave empty to run without PowerSync (direct API only)
# Auth: PowerSync receives the Supabase JWT automatically — no separate token needed
VITE_POWERSYNC_URL=

# ── Literature databases (all free — API keys optional but raise rate limits) ─
# NCBI API key — get free at: https://www.ncbi.nlm.nih.gov/account/
# Raises PubMed rate limit from 3 req/s → 10 req/s
NCBI_API_KEY=

# Semantic Scholar API key — get free at: https://www.semanticscholar.org/product/api
# Required for citation graph feature at scale (10 req/s vs 1 req/s)
SEMANTIC_SCHOLAR_API_KEY=

# OpenAlex polite pool — just your contact email, no registration needed
# Enables higher rate limits from OpenAlex (100 req/s vs 10 req/s)
OPENALEX_EMAIL=

# SearxNG / Vane — self-hosted meta-search (optional but highly recommended)
# When set, adds Google Scholar, arXiv, CrossRef, BASE to every search.
# Google Scholar is only accessible via SearxNG — there is no public API.
#
# Option A — run Vane (recommended, has a nice research-focused UI):
#   https://github.com/ItzCrazyKns/Vane
#   docker-compose up  →  set SEARXNG_URL=http://localhost:3001
#
# Option B — run bare SearxNG:
#   docker run -d -p 8080:8080 searxng/searxng
#   set SEARXNG_URL=http://localhost:8080
SEARXNG_URL=

# ── Obsidian vault sync ───────────────────────────────────────────────────────
# Absolute path to your Obsidian vault folder.
# Run: npm run sync:obsidian        (one-shot)
# Run: npm run sync:obsidian:watch  (re-sync every 30s while app is running)
OBSIDIAN_VAULT_PATH=
# How often to re-sync in watch mode (milliseconds, default 30000)
SYNC_INTERVAL_MS=30000

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
